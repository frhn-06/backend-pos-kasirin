  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    },
    "schemas": {
      "RegisterRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "@gmail.com"
          },
          "fullName": {
            "type": "string",
            "example": "namalengkap"
          },
          "userName": {
            "type": "string",
            "example": "username"
          },
          "password": {
            "type": "string",
            "example": "p"
          },
          "confirmPassword": {
            "type": "string",
            "example": "confirm p"
          }
        }
      },
      "ActivationRequest": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "example": "123"
          }
        }
      },
      "LoginRequest": {
        "type": "object",
        "properties": {
          "identifier": {
            "type": "string",
            "example": "alwanbocil@gmail.com / username"
          },
          "password": {
            "type": "string",
            "example": "p"
          }
        }
      },
      "UpdateUserRequest": {
        "type": "object",
        "properties": {
          "fullName": {
            "type": "string",
            "example": "namalengkap"
          },
          "userName": {
            "type": "string",
            "example": "username"
          }
        }
      },
      "UpdatePasswordUserRequest": {
        "type": "object",
        "properties": {
          "oldPassword": {
            "type": "string",
            "example": "p lama"
          },
          "newPassword": {
            "type": "string",
            "example": "p baru"
          },
          "confirmNewPassword": {
            "type": "string",
            "example": "confirm p baru"
          }
        }
      },
      "StoreRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "nama toko"
          },
          "address": {
            "type": "string",
            "example": "Jl. sudirman"
          },
          "phone": {
            "type": "number",
            "example": 857
          },
          "description": {
            "type": "string",
            "example": ""
          },
          "timeZone": {
            "type": "string",
            "example": ""
          }
        }
      },
      "CategoryRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
